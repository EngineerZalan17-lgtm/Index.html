<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome</title>
<style>
:root {
    color-scheme: dark;
    font-family: Segoe UI, Arial, sans-serif;
}
body {
    margin: 0;
    min-height: 100vh;
    overflow: hidden;
    background: radial-gradient(circle at top, #1f2937 0%, #0b1120 45%, #05080f 100%);
    color: #eef2ff;
}
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.9) 1px, transparent 0),
                      radial-gradient(circle, rgba(255,255,255,0.7) 1px, transparent 0);
    background-size: 90px 90px, 140px 140px;
    opacity: 0.55;
    pointer-events: none;
}
.scene {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 24px;
}
.moon {
    position: absolute;
    top: 40px;
    right: 40px;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #f8fafc, #94a3b8 60%, #0b1120 100%);
    box-shadow: 0 0 38px rgba(248,250,252,0.22);
}
.ground {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 180px;
    background: linear-gradient(180deg, transparent 0%, #03060c 75%, #02040a 100%);
}
.tree {
    position: absolute;
    bottom: 0;
    width: 0;
    border-left: 36px solid transparent;
    border-right: 36px solid transparent;
    border-bottom: 140px solid rgba(15, 23, 42, 0.9);
}
.tree::before {
    content: '';
    position: absolute;
    bottom: 70px;
    left: -46px;
    width: 0;
    border-left: 24px solid transparent;
    border-right: 24px solid transparent;
    border-bottom: 100px solid rgba(15, 23, 42, 0.85);
}
.tree.left {
    left: 22px;
}
.tree.right {
    right: 20px;
    transform: scaleX(-1);
}
.card {
    position: relative;
    width: 420px;
    padding: 36px;
    border-radius: 32px;
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.45);
    text-align: center;
    z-index: 1;
}
.robot {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 24px;
    border-radius: 28px;
    background: radial-gradient(circle at 30% 20%, #f8fafc 0%, #cbd5e1 48%, #94a3b8 100%);
    box-shadow: inset 0 10px 24px rgba(255,255,255,0.35), 0 12px 28px rgba(0,0,0,0.2);
    animation: floatRobot 3s ease-in-out infinite;
}
.robot::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 18px;
    height: 34px;
    border-radius: 12px;
    background: linear-gradient(180deg, #f8fafc, #94a3b8);
}
.robot::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 16px;
    background: rgba(15, 23, 42, 0.7);
    border-radius: 999px;
}
.robot .eye {
    position: absolute;
    top: 36px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #111827;
    box-shadow: inset 0 2px 3px rgba(255,255,255,0.5);
}
.robot .eye.left { left: 28px; }
.robot .eye.right { right: 28px; }
.robot .mouth {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    width: 62px;
    height: 24px;
    border-radius: 0 0 999px 999px;
    background: #111827;
}
.robot .mouth::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 10px;
    border-radius: 999px;
    background: #f8fafc;
}
@keyframes floatRobot {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px) rotate(-1deg); }
}
.card h1 {
    margin-bottom: 16px;
    font-size: 34px;
}
.card p {
    margin-bottom: 24px;
    color: #cbd5e1;
    line-height: 1.7;
    font-size: 16px;
}
.button {
    display: inline-block;
    padding: 14px 28px;
    border-radius: 16px;
    color: white;
    background: linear-gradient(135deg, #38bdf8, #8b5cf6);
    text-decoration: none;
    font-size: 16px;
    box-shadow: 0 16px 32px rgba(59, 130, 246, 0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
}
.button:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 38px rgba(59, 130, 246, 0.35);
    filter: brightness(1.05);
}

.progress {
    width: 100%;
    height: 14px;
    margin: 14px auto 22px;
    border-radius: 12px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
    box-shadow: inset 0 1px 3px rgba(255,255,255,0.12);
}

.progress-fill {
    width: 52%;
    height: 100%;
    background: linear-gradient(90deg, #38bdf8, #8b5cf6);
    animation: fillProgress 2s ease forwards;
}

.progress-label {
    color: #cbd5e1;
    font-size: 15px;
    margin-top: 12px;
    letter-spacing: 0.02em;
}

.progress-label .dots::after {
    content: '...';
    opacity: 0;
    animation: blinkDots 1.5s infinite;
    display: inline-block;
    margin-left: 6px;
}

@keyframes blinkDots {
    0%, 40% { opacity: 0; }
    60%, 100% { opacity: 1; }
}

@keyframes fillProgress {
    from { width: 0%; }
    to { width: 52%; }
}
</style>
</head>
<body>
<div class="scene">
    <div class="moon"></div>
    <div class="stars"></div>
    <div class="tree left"></div>
    <div class="tree right"></div>
    <div class="ground"></div>
    <div class="card">
        <div class="robot">
            <div class="eye left"></div>
            <div class="eye right"></div>
            <div class="mouth"></div>
        </div>
        <h1>Welcome Back</h1>
        <p>Your login is complete. Enjoy the dark sky and robot watch for a live, polished view.</p>
        <div class="progress">
            <div class="progress-fill"></div>
        </div>
        <div class="progress-label"> still in progress<span class="dots"></span></div>
        <a class="button" href="Login.html">Return to Login</a>
    </div>
</div>
</body>
</html>
